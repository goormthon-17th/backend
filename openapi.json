{
  "openapi": "3.0.3",
  "info": {
    "title": "Backend API",
    "version": "1.0.0",
    "description": "Swagger UI: `/api/docs`"
  },
  "servers": [{ "url": "/" }],
  "tags": [
    { "name": "API", "description": "상태" },
    { "name": "AI", "description": "Gemini" },
    { "name": "Database", "description": "MySQL" },
    { "name": "Health", "description": "헬스" },
    { "name": "Auth", "description": "회원" },
    { "name": "Recipe", "description": "레시피" }
  ],
  "paths": {
    "/api": {
      "get": {
        "tags": ["API"],
        "summary": "백엔드 동작 확인",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": { "type": "boolean" },
                    "message": { "type": "string" },
                    "path": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/db/ping": {
      "get": {
        "tags": ["Database"],
        "summary": "MySQL 연결 확인",
        "responses": {
          "200": { "description": "OK" },
          "503": { "description": "DB 미설정" }
        }
      }
    },
    "/health": {
      "get": {
        "tags": ["Health"],
        "summary": "Liveness",
        "responses": {
          "200": { "description": "OK" }
        }
      }
    },
    "/api/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "회원가입 (비밀번호 평문 저장)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["loginId", "password", "nickname"],
                "properties": {
                  "loginId": { "type": "string" },
                  "password": { "type": "string" },
                  "nickname": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Created" },
          "400": { "description": "Bad request" },
          "409": { "description": "loginId 중복" },
          "503": { "description": "DB 미설정" }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "로그인 → JWT (페이로드에 user 전체 필드)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["loginId", "password"],
                "properties": {
                  "loginId": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "OK — token, user" },
          "400": { "description": "Bad request" },
          "401": { "description": "인증 실패" },
          "503": { "description": "DB 미설정" }
        }
      }
    },
    "/api/recipes/latest": {
      "get": {
        "tags": ["Recipe"],
        "summary": "레시피 최신순 최대 20개",
        "responses": {
          "200": {
            "description": "ok, recipes[] (최대 20건) — id, recipe_name, created_at{year,month,day}, like_count, refined_text, image_url"
          },
          "503": { "description": "DB 미설정" }
        }
      }
    },
    "/api/recipes/by-likes": {
      "get": {
        "tags": ["Recipe"],
        "summary": "레시피 좋아요순 최대 20개 (동점 시 최신순)",
        "responses": {
          "200": {
            "description": "ok, recipes[] (최대 20건) — 필드 동일"
          },
          "503": { "description": "DB 미설정" }
        }
      }
    },
    "/api/recipes/user/{userId}": {
      "get": {
        "tags": ["Recipe"],
        "summary": "특정 유저가 등록한 레시피 목록 (최신순, 전체 행)",
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "minimum": 1 }
          }
        ],
        "responses": {
          "200": {
            "description": "ok, user_id, recipes[] — latest 목록과 동일 필드"
          },
          "400": { "description": "잘못된 userId" },
          "404": { "description": "user 없음" },
          "503": { "description": "DB 미설정" }
        }
      }
    },
    "/api/recipes": {
      "post": {
        "tags": ["Recipe"],
        "security": [{ "bearerAuth": [] }],
        "summary": "레시피 등록 (Swagger 상단 Authorize에 JWT 넣거나 curl에 -H Authorization: Bearer … — 없으면 user_id 1)",
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "required": false,
            "schema": { "type": "string" },
            "description": "`Bearer <token>` 또는 JWT 문자열만 (Swagger에 토큰만 붙여넣은 경우 대응)"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "raw_text": { "type": "string" },
                  "refined_text": { "type": "string" },
                  "audio_url": { "type": "string" },
                  "image_url": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Created — id, user_id" },
          "400": { "description": "FK 등" },
          "503": { "description": "DB 미설정" }
        }
      }
    },
    "/api/recipes/{recipeId}/like": {
      "post": {
        "tags": ["Recipe"],
        "security": [{ "bearerAuth": [] }],
        "summary": "레시피 좋아요 토글 (JWT 없으면 user_id 1 — 켜짐 201 liked true, 꺼짐 200 liked false)",
        "parameters": [
          {
            "name": "recipeId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "minimum": 1 }
          },
          {
            "name": "Authorization",
            "in": "header",
            "required": false,
            "schema": { "type": "string" },
            "description": "`Bearer <token>` 또는 JWT만"
          }
        ],
        "responses": {
          "201": { "description": "좋아요 켬 — liked true, like_count 증가" },
          "200": { "description": "좋아요 끔 — liked false, like_count 감소" },
          "400": { "description": "잘못된 recipeId / user FK" },
          "404": { "description": "레시피 없음" },
          "503": { "description": "DB 미설정" }
        }
      }
    },
    "/api/ai/generate": {
      "post": {
        "tags": ["AI"],
        "summary": "STT 원문 → 레시피 카드 (서버 고정 프롬프트). image_url·audio_url 필수 — 응답에 그대로 포함되어 POST /api/recipes에 재사용 가능",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["text", "image_url", "audio_url"],
                "properties": {
                  "text": { "type": "string", "description": "STT 원문" },
                  "image_url": { "type": "string", "description": "레시피 이미지 URL (recipe.image_url)" },
                  "audio_url": { "type": "string", "description": "음성 URL (recipe.audio_url)" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": { "type": "boolean" },
                    "resultText": { "type": "string" },
                    "image_url": { "type": "string" },
                    "audio_url": { "type": "string" }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "502": { "description": "Gemini 오류" },
          "503": { "description": "API 키 없음" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "POST /api/auth/login 의 응답 token 값만 입력 (Bearer 접두어는 Swagger가 붙임)"
      }
    }
  }
}
