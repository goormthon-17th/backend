{
  "openapi": "3.0.3",
  "info": {
    "title": "Backend API",
    "version": "1.0.0",
    "description": "goormthon backend — 스키마: user, recipe, recipe_like, user_subscribe (init.sql)"
  },
  "servers": [{ "url": "/" }],
  "paths": {
    "/api": {
      "get": {
        "summary": "상태 확인",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": { "type": "boolean" },
                    "message": { "type": "string" },
                    "path": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/test": {
      "get": {
        "summary": "배포/헬스 확인",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": { "type": "boolean" },
                    "endpoint": { "type": "string" },
                    "deployCheck": { "type": "string" },
                    "at": { "type": "string", "format": "date-time" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/db/ping": {
      "get": {
        "summary": "MySQL 연결 확인",
        "responses": {
          "200": { "description": "OK" },
          "503": { "description": "DB 미설정" }
        }
      }
    },
    "/health": {
      "get": {
        "summary": "Liveness",
        "responses": {
          "200": { "description": "OK" }
        }
      }
    },
    "/api/ai/refine": {
      "post": {
        "summary": "텍스트 Gemini 정제",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["text"],
                "properties": {
                  "text": { "type": "string", "description": "원문" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": { "type": "boolean" },
                    "refinedText": { "type": "string" }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "502": { "description": "Gemini 오류" },
          "503": { "description": "GEMINI_API_KEY 없음" }
        }
      }
    }
  }
}
