{
  "openapi": "3.0.3",
  "info": {
    "title": "Backend API",
    "version": "1.0.0",
    "description": "Swagger UI: `/api/docs`"
  },
  "servers": [{ "url": "/" }],
  "tags": [
    { "name": "API", "description": "상태" },
    { "name": "AI", "description": "Gemini" },
    { "name": "Voice", "description": "음성 업로드" },
    { "name": "Database", "description": "MySQL" },
    { "name": "Health", "description": "헬스" },
    { "name": "Auth", "description": "회원" },
    { "name": "Recipe", "description": "레시피" },
    { "name": "User", "description": "유저 프로필" },
    { "name": "Upload", "description": "파일 업로드" }
  ],
  "paths": {
    "/api": {
      "get": {
        "tags": ["API"],
        "summary": "백엔드 동작 확인",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": { "type": "boolean" },
                    "message": { "type": "string" },
                    "path": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/db/ping": {
      "get": {
        "tags": ["Database"],
        "summary": "MySQL 연결 확인",
        "responses": {
          "200": { "description": "OK" },
          "503": { "description": "DB 미설정" }
        }
      }
    },
    "/api/db/clear/user": {
      "post": {
        "tags": ["Database"],
        "summary": "TRUNCATE `user` — body { \"code\": \"1234\" } 필수",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["code"],
                "properties": {
                  "code": { "type": "string", "example": "1234" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "ok, table: user" },
          "400": { "description": "JSON body 없음" },
          "403": { "description": "code 가 1234 아님" },
          "503": { "description": "DB 미설정" },
          "500": { "description": "SQL 오류" }
        }
      }
    },
    "/api/db/clear/recipe": {
      "post": {
        "tags": ["Database"],
        "summary": "TRUNCATE recipe — body { \"code\": \"1234\" }",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["code"],
                "properties": {
                  "code": { "type": "string", "example": "1234" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "ok, table: recipe" },
          "400": { "description": "JSON body 없음" },
          "403": { "description": "code 불일치" },
          "503": { "description": "DB 미설정" },
          "500": { "description": "SQL 오류" }
        }
      }
    },
    "/api/db/clear/recipe-like": {
      "post": {
        "tags": ["Database"],
        "summary": "TRUNCATE recipe_like — body { \"code\": \"1234\" }",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["code"],
                "properties": {
                  "code": { "type": "string", "example": "1234" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "ok, table: recipe_like" },
          "400": { "description": "JSON body 없음" },
          "403": { "description": "code 불일치" },
          "503": { "description": "DB 미설정" },
          "500": { "description": "SQL 오류" }
        }
      }
    },
    "/api/db/clear/recipe-review": {
      "post": {
        "tags": ["Database"],
        "summary": "TRUNCATE recipe_review — body { \"code\": \"1234\" }",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["code"],
                "properties": {
                  "code": { "type": "string", "example": "1234" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "ok, table: recipe_review" },
          "400": { "description": "JSON body 없음" },
          "403": { "description": "code 불일치" },
          "503": { "description": "DB 미설정" },
          "500": { "description": "SQL 오류" }
        }
      }
    },
    "/api/db/clear/user-subscribe": {
      "post": {
        "tags": ["Database"],
        "summary": "TRUNCATE user_subscribe — body { \"code\": \"1234\" }",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["code"],
                "properties": {
                  "code": { "type": "string", "example": "1234" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "ok, table: user_subscribe" },
          "400": { "description": "JSON body 없음" },
          "403": { "description": "code 불일치" },
          "503": { "description": "DB 미설정" },
          "500": { "description": "SQL 오류" }
        }
      }
    },
    "/health": {
      "get": {
        "tags": ["Health"],
        "summary": "Liveness",
        "responses": {
          "200": { "description": "OK" }
        }
      }
    },
    "/api/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "회원가입 (비밀번호 평문 저장)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["loginId", "password", "nickname"],
                "properties": {
                  "loginId": { "type": "string" },
                  "password": { "type": "string" },
                  "nickname": { "type": "string" },
                  "profile_image_url": { "type": "string", "description": "선택, 프로필 이미지 URL" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Created — user에 profile_image_url 포함" },
          "400": { "description": "Bad request" },
          "409": { "description": "loginId 중복" },
          "503": { "description": "DB 미설정" }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "로그인 → JWT (페이로드에 user 전체 필드)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["loginId", "password"],
                "properties": {
                  "loginId": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "OK — token, user" },
          "400": { "description": "Bad request" },
          "401": { "description": "인증 실패" },
          "503": { "description": "DB 미설정" }
        }
      }
    },
    "/api/users/following": {
      "get": {
        "tags": ["User"],
        "security": [{ "bearerAuth": [] }],
        "summary": "내가 구독 중인 유저 목록 최대 20 (profile_image_url 유저 / recipe_image_url 레시피)",
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "required": false,
            "schema": { "type": "string" },
            "description": "`Bearer <token>` 또는 JWT만 — 없으면 follower 1 기준"
          }
        ],
        "responses": {
          "200": {
            "description": "ok, users[] — user_id, nickname, profile_image_url, recipe_image_url"
          },
          "503": { "description": "DB 미설정" }
        }
      }
    },
    "/api/users/{userId}/subscribe": {
      "post": {
        "tags": ["User"],
        "security": [{ "bearerAuth": [] }],
        "summary": "구독 토글 (JWT 없으면 follower_id 1 — 구독 201, 해제 200)",
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "minimum": 1 },
            "description": "구독 대상 사용자 id (following_id)"
          },
          {
            "name": "Authorization",
            "in": "header",
            "required": false,
            "schema": { "type": "string" },
            "description": "`Bearer <token>` 또는 JWT만"
          }
        ],
        "responses": {
          "201": { "description": "구독됨 — subscribed true, follower_id, following_id" },
          "200": { "description": "구독 해제됨 — subscribed false" },
          "400": { "description": "본인 구독 / 잘못된 id / FK" },
          "404": { "description": "대상 user 없음" },
          "503": { "description": "DB 미설정" }
        }
      }
    },
    "/api/users/{userId}": {
      "get": {
        "tags": ["User"],
        "summary": "유저 프로필 요약 + is_subscribed (Bearer 없으면 viewer=user 1)",
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "minimum": 1 }
          },
          {
            "name": "Authorization",
            "in": "header",
            "required": false,
            "schema": { "type": "string" },
            "description": "선택 — 없거나 무효면 구독 여부는 follower_id=1 기준"
          }
        ],
        "responses": {
          "200": {
            "description": "ok, user_id, nickname, profile_image_url, recipe_count, recipe_likes_total, following_count, is_subscribed"
          },
          "400": { "description": "잘못된 userId" },
          "404": { "description": "user 없음" },
          "503": { "description": "DB 미설정" }
        }
      }
    },
    "/api/recipes/latest": {
      "get": {
        "tags": ["Recipe"],
        "summary": "레시피 최신순 최대 20개",
        "responses": {
          "200": {
            "description": "ok, recipes[] — profile_image_url(작성자), recipe_image_url(레시피), id, user_id, nickname, recipe_name, created_at, like_count, refined_text"
          },
          "503": { "description": "DB 미설정" }
        }
      }
    },
    "/api/recipes/by-likes": {
      "get": {
        "tags": ["Recipe"],
        "summary": "레시피 좋아요순 최대 20개 (동점 시 최신순)",
        "responses": {
          "200": {
            "description": "ok, recipes[] — /latest 와 동일 (profile_image_url, recipe_image_url 구분)"
          },
          "503": { "description": "DB 미설정" }
        }
      }
    },
    "/api/recipes/liked": {
      "get": {
        "tags": ["Recipe"],
        "summary": "내가 좋아요한 레시피 목록 (좋아요 누른 순 최신, 최대 200)",
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "required": false,
            "schema": { "type": "string" },
            "description": "선택 — 없으면 user_id=1이 좋아요한 목록"
          }
        ],
        "responses": {
          "200": {
            "description": "ok, recipes[] — id, recipe_name, refined_text(내용), like_count, image_url, created_at { year, month, day } (레시피 작성일)"
          },
          "503": { "description": "DB 미설정" }
        }
      }
    },
    "/api/recipes/search": {
      "get": {
        "tags": ["Recipe"],
        "summary": "키워드 검색 — recipe_name에 연속 일치 또는 글자 하나라도 일치. 응답 recipes[]는 /latest 와 동일",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "검색 키워드"
          }
        ],
        "responses": {
          "200": {
            "description": "ok, recipes[] — /latest 와 동일 필드"
          },
          "400": { "description": "q 없음 또는 너무 김" },
          "503": { "description": "DB 미설정" }
        }
      }
    },
    "/api/recipes/user/{userId}": {
      "get": {
        "tags": ["Recipe"],
        "summary": "특정 유저가 등록한 레시피 목록 (최신순, 전체 행)",
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "minimum": 1 }
          }
        ],
        "responses": {
          "200": {
            "description": "ok, user_id(프로필 주인), recipes[] — /latest 와 동일 필드"
          },
          "400": { "description": "잘못된 userId" },
          "404": { "description": "user 없음" },
          "503": { "description": "DB 미설정" }
        }
      }
    },
    "/api/recipes/{recipeId}": {
      "get": {
        "tags": ["Recipe"],
        "summary": "레시피 상세 (썸네일·이름·작성일·좋아요·원문·정제문·리뷰 전체)",
        "parameters": [
          {
            "name": "recipeId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "minimum": 1 }
          }
        ],
        "responses": {
          "200": {
            "description": "ok — reviews[] 항목의 created_at·updated_at 은 { year, month, day } (DB 기준), 레시피 본문 created_at 동일"
          },
          "400": { "description": "잘못된 recipeId" },
          "404": { "description": "레시피 없음" },
          "503": { "description": "DB 미설정" }
        }
      },
      "patch": {
        "tags": ["Recipe"],
        "security": [{ "bearerAuth": [] }],
        "summary": "레시피 수정 — 작성자만 (JWT 없으면 user_id 1만 id 일치 시 가능)",
        "parameters": [
          {
            "name": "recipeId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "minimum": 1 }
          },
          {
            "name": "Authorization",
            "in": "header",
            "required": false,
            "schema": { "type": "string" },
            "description": "`Bearer <token>`"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "minProperties": 1,
                "properties": {
                  "image_url": {
                    "type": "string",
                    "description": "http(s) 또는 / 로 시작하는 경로(음성 API와 동일 정규화). 빈 문자열이면 썸네일 제거"
                  },
                  "raw_text": { "type": "string", "description": "STT/원문" },
                  "refined_text": { "type": "string", "description": "정제 본문 전체 교체" },
                  "recipe_name": { "type": "string", "description": "표시 이름 — refined_text의 '레시피 제목:' 줄 또는 첫 줄 갱신" },
                  "name": { "type": "string", "description": "recipe_name 별칭" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "ok — id, recipe_name, recipe_image_url, raw_text, refined_text"
          },
          "400": { "description": "recipeId / image_url 형식 / 갱신 필드 없음" },
          "403": { "description": "작성자 아님" },
          "404": { "description": "레시피 없음" },
          "503": { "description": "DB 미설정" }
        }
      }
    },
    "/api/recipes/{recipeId}/reviews": {
      "post": {
        "tags": ["Recipe"],
        "security": [{ "bearerAuth": [] }],
        "summary": "리뷰 작성·같은 유저 재요청 시 수정 (JWT 없으면 user_id 1)",
        "parameters": [
          {
            "name": "recipeId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "minimum": 1 }
          },
          {
            "name": "Authorization",
            "in": "header",
            "required": false,
            "schema": { "type": "string" },
            "description": "`Bearer <token>` 또는 JWT만"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "content": { "type": "string", "description": "리뷰 본문 (선택)" },
                  "emo_1": { "type": "boolean", "description": "또는 emo1" },
                  "emo_2": { "type": "boolean" },
                  "emo_3": { "type": "boolean" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "신규 — review.created_at·updated_at 은 { year, month, day }" },
          "200": { "description": "수정(UPSERT) — 동일" },
          "400": { "description": "FK 등" },
          "404": { "description": "레시피 없음" },
          "503": { "description": "DB 미설정" }
        }
      }
    },
    "/api/recipes": {
      "post": {
        "tags": ["Recipe"],
        "security": [{ "bearerAuth": [] }],
        "summary": "레시피 등록 (Swagger 상단 Authorize에 JWT 넣거나 curl에 -H Authorization: Bearer … — 없으면 user_id 1)",
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "required": false,
            "schema": { "type": "string" },
            "description": "`Bearer <token>` 또는 JWT 문자열만 (Swagger에 토큰만 붙여넣은 경우 대응)"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "raw_text": { "type": "string" },
                  "refined_text": { "type": "string" },
                  "image_url": { "type": "string", "description": "레시피 썸네일 → DB recipe.image_url" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Created — id, user_id" },
          "400": { "description": "FK 등" },
          "503": { "description": "DB 미설정" }
        }
      }
    },
    "/api/recipes/{recipeId}/like": {
      "post": {
        "tags": ["Recipe"],
        "security": [{ "bearerAuth": [] }],
        "summary": "레시피 좋아요 토글 (JWT 없으면 user_id 1 — 켜짐 201 liked true, 꺼짐 200 liked false)",
        "parameters": [
          {
            "name": "recipeId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "minimum": 1 }
          },
          {
            "name": "Authorization",
            "in": "header",
            "required": false,
            "schema": { "type": "string" },
            "description": "`Bearer <token>` 또는 JWT만"
          }
        ],
        "responses": {
          "201": { "description": "좋아요 켬 — liked true, like_count 증가" },
          "200": { "description": "좋아요 끔 — liked false, like_count 감소" },
          "400": { "description": "잘못된 recipeId / user FK" },
          "404": { "description": "레시피 없음" },
          "503": { "description": "DB 미설정" }
        }
      }
    },
    "/api/ai/generate": {
      "post": {
        "tags": ["AI"],
        "summary": "STT 원문 → 레시피 카드 (서버 고정 프롬프트)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["text"],
                "properties": {
                  "text": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": { "type": "boolean" },
                    "resultText": { "type": "string" }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "502": { "description": "Gemini 오류" },
          "503": { "description": "API 키 없음" }
        }
      }
    },
    "/api/voice": {
      "post": {
        "tags": ["Voice"],
        "summary": "음성 → STT → 정제 → TTS; image_url 있으면 절대 URL로 정규화 후 recipe 저장·응답 에코",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["audio"],
                "properties": {
                  "audio": {
                    "type": "string",
                    "format": "binary",
                    "description": "음성 바이너리 (예: audio/webm, audio/wav)"
                  },
                  "image_url": {
                    "type": "string",
                    "description": "선택 — https URL 또는 /uploads/... 경로. PUBLIC_BASE_URL(기본 goormthon 호스트)로 절대 URL 합성·DB 저장"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "multipart — text, image_url(절대 URL), recipe_id(DB 저장 성공 시), audio 또는 tts_error",
            "content": {
              "multipart/form-data": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "text": { "type": "string" },
                    "image_url": { "type": "string", "description": "브라우저에서 바로 로드 가능한 https URL" },
                    "recipe_id": { "type": "string", "description": "recipe 행 id (저장 실패 시 생략)" },
                    "audio": { "type": "string", "format": "binary", "description": "WAV" },
                    "tts_error": { "type": "string" }
                  }
                }
              }
            }
          },
          "400": { "description": "audio 없음, image_url 형식 오류 등 — text/plain" },
          "413": { "description": "용량 초과 — text/plain" },
          "502": { "description": "Clova/Gemini 오류 — text/plain 메시지" },
          "503": { "description": "환경변수 미설정 — text/plain 메시지" }
        }
      }
    },
    "/api/upload/image": {
      "post": {
        "tags": ["Upload"],
        "summary": "이미지 디스크 저장 후 URL 경로 반환 (GET /uploads/파일명 으로 조회)",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["image"],
                "properties": {
                  "image": {
                    "type": "string",
                    "format": "binary",
                    "description": "JPEG / PNG / WebP / GIF"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "ok, path(/uploads/...), filename, url(PUBLIC_BASE_URL 설정 시 절대 URL)"
          },
          "400": { "description": "필드 없음·이미지 타입 아님" },
          "413": { "description": "용량 초과 (UPLOAD_MAX_IMAGE_BYTES)" },
          "500": { "description": "저장 실패" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "POST /api/auth/login 의 응답 token 값만 입력 (Bearer 접두어는 Swagger가 붙임)"
      }
    }
  }
}
