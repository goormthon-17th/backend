{
  "openapi": "3.0.3",
  "info": {
    "title": "Backend API",
    "version": "1.0.0",
    "description": "Swagger UI: `/api/docs`"
  },
  "servers": [{ "url": "/" }],
  "tags": [
    { "name": "API", "description": "상태" },
    { "name": "AI", "description": "Gemini" },
    { "name": "Database", "description": "MySQL" },
    { "name": "Health", "description": "헬스" }
  ],
  "paths": {
    "/api": {
      "get": {
        "tags": ["API"],
        "summary": "백엔드 동작 확인",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": { "type": "boolean" },
                    "message": { "type": "string" },
                    "path": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/db/ping": {
      "get": {
        "tags": ["Database"],
        "summary": "MySQL 연결 확인",
        "responses": {
          "200": { "description": "OK" },
          "503": { "description": "DB 미설정" }
        }
      }
    },
    "/health": {
      "get": {
        "tags": ["Health"],
        "summary": "Liveness",
        "responses": {
          "200": { "description": "OK" }
        }
      }
    },
    "/api/ai/generate": {
      "post": {
        "tags": ["AI"],
        "summary": "STT 원문 → 레시피 카드 (instruction 생략 시 서버 기본 프롬프트)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["text"],
                "properties": {
                  "text": { "type": "string" },
                  "instruction": {
                    "type": "string",
                    "description": "선택. 없으면 서버 기본 지시문"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": { "type": "boolean" },
                    "resultText": { "type": "string" }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "502": { "description": "Gemini 오류" },
          "503": { "description": "API 키 없음" }
        }
      }
    }
  }
}
