{
  "openapi": "3.0.3",
  "info": {
    "title": "Backend API",
    "version": "1.0.0",
    "description": "Swagger UI: `/api/docs`"
  },
  "servers": [{ "url": "/" }],
  "tags": [
    { "name": "API", "description": "상태" },
    { "name": "AI", "description": "Gemini" },
    { "name": "Database", "description": "MySQL" },
    { "name": "Health", "description": "헬스" },
    { "name": "Auth", "description": "회원" },
    { "name": "Recipe", "description": "레시피" },
    { "name": "User", "description": "유저 프로필" }
  ],
  "paths": {
    "/api": {
      "get": {
        "tags": ["API"],
        "summary": "백엔드 동작 확인",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": { "type": "boolean" },
                    "message": { "type": "string" },
                    "path": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/db/ping": {
      "get": {
        "tags": ["Database"],
        "summary": "MySQL 연결 확인",
        "responses": {
          "200": { "description": "OK" },
          "503": { "description": "DB 미설정" }
        }
      }
    },
    "/health": {
      "get": {
        "tags": ["Health"],
        "summary": "Liveness",
        "responses": {
          "200": { "description": "OK" }
        }
      }
    },
    "/api/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "회원가입 (비밀번호 평문 저장)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["loginId", "password", "nickname"],
                "properties": {
                  "loginId": { "type": "string" },
                  "password": { "type": "string" },
                  "nickname": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Created" },
          "400": { "description": "Bad request" },
          "409": { "description": "loginId 중복" },
          "503": { "description": "DB 미설정" }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "로그인 → JWT (페이로드에 user 전체 필드)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["loginId", "password"],
                "properties": {
                  "loginId": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "OK — token, user" },
          "400": { "description": "Bad request" },
          "401": { "description": "인증 실패" },
          "503": { "description": "DB 미설정" }
        }
      }
    },
    "/api/users/following": {
      "get": {
        "tags": ["User"],
        "security": [{ "bearerAuth": [] }],
        "summary": "내가 구독 중인 유저 목록 최대 20 (user_id, nickname, 대표 recipe image_url)",
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "required": false,
            "schema": { "type": "string" },
            "description": "`Bearer <token>` 또는 JWT만 — 없으면 follower 1 기준"
          }
        ],
        "responses": {
          "200": {
            "description": "ok, users[] — user_id, nickname, image_url(레시피 썸네일 URL 또는 null)"
          },
          "503": { "description": "DB 미설정" }
        }
      }
    },
    "/api/users/{userId}/subscribe": {
      "post": {
        "tags": ["User"],
        "security": [{ "bearerAuth": [] }],
        "summary": "구독 토글 (JWT 없으면 follower_id 1 — 구독 201, 해제 200)",
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "minimum": 1 },
            "description": "구독 대상 사용자 id (following_id)"
          },
          {
            "name": "Authorization",
            "in": "header",
            "required": false,
            "schema": { "type": "string" },
            "description": "`Bearer <token>` 또는 JWT만"
          }
        ],
        "responses": {
          "201": { "description": "구독됨 — subscribed true, follower_id, following_id" },
          "200": { "description": "구독 해제됨 — subscribed false" },
          "400": { "description": "본인 구독 / 잘못된 id / FK" },
          "404": { "description": "대상 user 없음" },
          "503": { "description": "DB 미설정" }
        }
      }
    },
    "/api/users/{userId}": {
      "get": {
        "tags": ["User"],
        "summary": "유저 프로필 요약 (닉네임, 레시피 수, 레시피 좋아요 합계, 구독 중인 사용자 수)",
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "minimum": 1 }
          }
        ],
        "responses": {
          "200": {
            "description": "ok, user_id, nickname, recipe_count, recipe_likes_total, following_count"
          },
          "400": { "description": "잘못된 userId" },
          "404": { "description": "user 없음" },
          "503": { "description": "DB 미설정" }
        }
      }
    },
    "/api/recipes/latest": {
      "get": {
        "tags": ["Recipe"],
        "summary": "레시피 최신순 최대 20개",
        "responses": {
          "200": {
            "description": "ok, recipes[] — id, user_id, nickname(작성자), recipe_name, created_at, like_count, refined_text, image_url"
          },
          "503": { "description": "DB 미설정" }
        }
      }
    },
    "/api/recipes/by-likes": {
      "get": {
        "tags": ["Recipe"],
        "summary": "레시피 좋아요순 최대 20개 (동점 시 최신순)",
        "responses": {
          "200": {
            "description": "ok, recipes[] — /latest 와 동일 필드 (user_id, nickname 포함)"
          },
          "503": { "description": "DB 미설정" }
        }
      }
    },
    "/api/recipes/user/{userId}": {
      "get": {
        "tags": ["Recipe"],
        "summary": "특정 유저가 등록한 레시피 목록 (최신순, 전체 행)",
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "minimum": 1 }
          }
        ],
        "responses": {
          "200": {
            "description": "ok, user_id(프로필 주인), recipes[] — 항목마다 작성자 user_id·nickname 포함"
          },
          "400": { "description": "잘못된 userId" },
          "404": { "description": "user 없음" },
          "503": { "description": "DB 미설정" }
        }
      }
    },
    "/api/recipes": {
      "post": {
        "tags": ["Recipe"],
        "security": [{ "bearerAuth": [] }],
        "summary": "레시피 등록 (Swagger 상단 Authorize에 JWT 넣거나 curl에 -H Authorization: Bearer … — 없으면 user_id 1)",
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "required": false,
            "schema": { "type": "string" },
            "description": "`Bearer <token>` 또는 JWT 문자열만 (Swagger에 토큰만 붙여넣은 경우 대응)"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "raw_text": { "type": "string" },
                  "refined_text": { "type": "string" },
                  "image_url": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Created — id, user_id" },
          "400": { "description": "FK 등" },
          "503": { "description": "DB 미설정" }
        }
      }
    },
    "/api/recipes/{recipeId}/like": {
      "post": {
        "tags": ["Recipe"],
        "security": [{ "bearerAuth": [] }],
        "summary": "레시피 좋아요 토글 (JWT 없으면 user_id 1 — 켜짐 201 liked true, 꺼짐 200 liked false)",
        "parameters": [
          {
            "name": "recipeId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "minimum": 1 }
          },
          {
            "name": "Authorization",
            "in": "header",
            "required": false,
            "schema": { "type": "string" },
            "description": "`Bearer <token>` 또는 JWT만"
          }
        ],
        "responses": {
          "201": { "description": "좋아요 켬 — liked true, like_count 증가" },
          "200": { "description": "좋아요 끔 — liked false, like_count 감소" },
          "400": { "description": "잘못된 recipeId / user FK" },
          "404": { "description": "레시피 없음" },
          "503": { "description": "DB 미설정" }
        }
      }
    },
    "/api/ai/generate": {
      "post": {
        "tags": ["AI"],
        "summary": "STT 원문 → 레시피 카드 (서버 고정 프롬프트)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["text"],
                "properties": {
                  "text": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": { "type": "boolean" },
                    "resultText": { "type": "string" }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "502": { "description": "Gemini 오류" },
          "503": { "description": "API 키 없음" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "POST /api/auth/login 의 응답 token 값만 입력 (Bearer 접두어는 Swagger가 붙임)"
      }
    }
  }
}
